# Azadexa / Orion — development environment (wave 0)
# Copy to .env and adjust secrets for local use.

FLASK_APP=orion.wsgi:app
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
# JWT signing — defaults to SECRET_KEY when unset; use a distinct value in production
JWT_SECRET_KEY=

# PostgreSQL (production database — dev + test + prod)
DATABASE_URL=postgresql://azadexa:azadexa_dev@localhost:5432/azadexa_dev

# Test suite — swap DATABASE_URL when running pytest (port 5433, docker-test-up):
# DATABASE_URL=postgresql://azadexa:azadexa_test@localhost:5433/azadexa_test

# Redis
REDIS_URL=redis://localhost:6379/0

# Monitoring (phase 14 — optional in dev)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.0
# PROMETHEUS_ENABLED=true
# LOG_JSON=false
# LOG_LEVEL=INFO

# Catalog cache (phase 14)
# CACHE_ENABLED=true
# CACHE_TTL_SECONDS=300

# Email (wave 15)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@azadexa.com

# Celery (wave 15 — defaults to REDIS_URL)
# CELERY_BROKER_URL=redis://localhost:6379/1

# Fernet key — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Emergency only — NOT for CI (breaks production parity):
# USE_SQLITE_TESTS=1

# External subdomain registry (optional — skipped when unset)
# TENANT_REGISTRY_URL=https://registry.internal.azadexa.com
